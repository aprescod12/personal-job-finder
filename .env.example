# Local Django development configuration.
DJANGO_SECRET_KEY=replace-with-a-long-local-development-value

# Keep the deterministic parser active until you deliberately enable AI extraction.
JOB_INTAKE_AI_ENABLED=false
JOB_INTAKE_EXTRACTOR=tracker.services.job_intake.DeterministicJobExtractor

# Step 3C fallback. When an AI primary fails, the deterministic parser creates a
# clearly labeled review draft instead of silently stopping or saving anything.
JOB_INTAKE_FALLBACK_ENABLED=true
JOB_INTAKE_FALLBACK_EXTRACTOR=tracker.services.job_intake.DeterministicJobExtractor

# Stage 5 resume extraction remains local and deterministic by default.
RESUME_AI_ENABLED=false
RESUME_EXTRACTOR=candidate_profile.services.resume_deterministic.DeterministicResumeExtractor
RESUME_FALLBACK_ENABLED=true
RESUME_FALLBACK_EXTRACTOR=candidate_profile.services.resume_deterministic.DeterministicResumeExtractor

# Add the real key only to your local .env file. Never commit it.
OPENAI_API_KEY=

# Job-listing AI extraction request configuration.
OPENAI_JOB_EXTRACTION_MODEL=gpt-5-mini
OPENAI_JOB_EXTRACTION_TIMEOUT_SECONDS=30
OPENAI_JOB_EXTRACTION_MAX_OUTPUT_TOKENS=4000

# Resume AI extraction request configuration. The first request uses a compact
# claims-only schema. A second request is allowed only when OpenAI reports that
# the first response reached its output-token limit.
OPENAI_RESUME_EXTRACTION_MODEL=gpt-5-mini
OPENAI_RESUME_EXTRACTION_TIMEOUT_SECONDS=120
OPENAI_RESUME_EXTRACTION_MAX_OUTPUT_TOKENS=8000
OPENAI_RESUME_EXTRACTION_RETRY_MAX_OUTPUT_TOKENS=12000
OPENAI_RESUME_EXTRACTION_MAX_INPUT_CHARS=60000
OPENAI_RESUME_EXTRACTION_REASONING_EFFORT=low

# Stage 6 live discovery is read-only and disabled by default. The board registry
# must be a JSON list of employers you deliberately approved. board_token is the
# token from the employer's Greenhouse job-board URL, not an API key.
JOB_DISCOVERY_LIVE_ENABLED=false
GREENHOUSE_DISCOVERY_BOARDS=[]
# Example kept commented so no employer is contacted by default:
# GREENHOUSE_DISCOVERY_BOARDS=[{"key":"approved-employer","label":"Approved Employer","board_token":"approved-employer","industry_hint":"Medical devices","enabled":true}]
GREENHOUSE_DISCOVERY_TIMEOUT_SECONDS=10
GREENHOUSE_DISCOVERY_RETRY_COUNT=1
GREENHOUSE_DISCOVERY_MAX_BOARDS=5
GREENHOUSE_DISCOVERY_MAX_JOBS_PER_BOARD=100
GREENHOUSE_DISCOVERY_USER_AGENT=AmirisJobFinder/1.0 controlled-discovery

# To activate the OpenAI job extractor later, change only your local .env file:
# JOB_INTAKE_AI_ENABLED=true
# JOB_INTAKE_EXTRACTOR=tracker.services.openai_job_extraction.OpenAIJobExtractor

# To activate the OpenAI resume extractor later, change only your local .env file:
# RESUME_AI_ENABLED=true
# RESUME_EXTRACTOR=candidate_profile.services.openai_resume_extraction.OpenAIResumeExtractor
